Proceso Busesexpress
	Definir nombre Como Caracter;
	Definir rut Como Caracter;
	Definir destino, asiento, i  Como Entero;
	Definir estudiante Como Caracter;
	Definir s,n Como Caracter;
	Definir precio_base,precio_final como real;
	
	//ciclo
	
	Para i<- 1 Hasta 5 Hacer
		Escribir "Compra N° ", i;
		
		
		//Datos de entradas
		Escribir "Ingresa tu nombre";
		Leer nombre;
		
		Escribir "Ingresa tu rut";
		Leer rut;
		
		//destino
		Escribir "Indica tu destino";
		Escribir "Santiago-$10.000";
		Escribir "Valpo-$8.000";
		Escribir "Conce-$15.000";
		Leer destino;
		Segun destino Hacer
			1:
				precio_base<-10000;
			2:
				precio_base<-8000;
			3:
				precio_base<-15000;
			De Otro Modo:
				Escribir "Ingrese un valor valido";
				precio_base<-0;
		FinSegun
		
		
		//Asientos
		
		Escribir "Seleccione su asiento";
		Escribir "1.Normal";
		Escribir "2.Semi-cama(20%+)";
		Escribir "3.Cama(40%+)";
		Leer asiento;
		
		
		
		
		Segun asiento Hacer
			1:
				precio_final<-precio_base;
			2:
				precio_final<-precio_base * 1.2;
			3:
				precio_final<-precio_base * 1.4;
			De Otro Modo:
				Escribir "Seleccione una opcion valida";
				precio_final<-precio_base;
		FinSegun
		
		
		//Estudiante	
		
		Escribir "Es usted estudiante?(s/n)";
		Leer estudiante;
		
		Si estudiante = "s" Entonces
			precio_final<-precio_base -2000 ;
			FinSi
			
			//Boleta
			
			Escribir "Boleta";
			Escribir "Hola:", nombre;
			Escribir "Tu numero de rut es: ",rut;
			Escribir "Buen viaje ,Tu destino es ",destino;
			Escribir "Su asiento es ", asiento;
			Escribir "Su total a cancelar es ", precio_final;
			Escribir "Que tenga un muy buen viaje ";
			
	FinPara
FinProceso
